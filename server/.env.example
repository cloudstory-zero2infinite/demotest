# Supabase — service role key (NEVER expose this in frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Frontend URL — used for CORS and for the policy deep-link in expiry reminder
# emails (<FRONTEND_URL>/?policyId=<id>). For local dev set http://localhost:5174.
FRONTEND_URL=http://localhost:5173

# Port
PORT=3001

# SMTP email — powers policy expiry reminder emails (server/src/lib/email.js).
# Use the SAME SMTP server configured for Supabase Auth so mail is sent from
# noreply@cloudstory.ind.in. If SMTP_HOST/USER/PASS are unset, emails are
# skipped (no crash). Port 587 = STARTTLS, 465 = implicit TLS.
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@cloudstory.ind.in

# Resend email (optional) — used by the in-app feedback form only (feedback.js).
RESEND_API_KEY=your-resend-key
RESEND_FROM_EMAIL=feedback@yourdomain.com
RESEND_TO_EMAIL=you@yourdomain.com

# AI Agent service (FastAPI) — Express proxies /api/mapper/* to this
AI_AGENT_URL=http://localhost:8080
