# Same Supabase project as the main app
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vite dev server (for CORS) — production same-origin so this can be empty
FRONTEND_URL=http://localhost:5175

PORT=3002

# Storage bucket name (defaults to "policy-corpus")
POLICY_CORPUS_BUCKET=policy-corpus

# Optional: filesystem path to ontology yml files. In the monorepo this
# defaults to ../ai-agent/ontology. Leave unset in production — the route
# returns a stub when the directory isn't available.
# ONTOLOGY_DIR=/path/to/ontology

# ───────── Queue Analytics / E2E test runner (qa.js) ─────────
# Dedicated pre-prod test account the runner logs in with (email/password,
# LOGIN_MODE=email). Required for the QA tab to start runs.
E2E_EMAIL=
E2E_PASSWORD=
# Pre-prod app the suite runs against (defaults to the pre-prod Cloud Run URL).
# PREPROD_BASE_URL=https://pre-prod-987276481381.asia-south1.run.app
# Prod app URL — set this to enable the "prod" option in the environment dropdown.
# The prod option only appears once this is configured. Same E2E_EMAIL/PASSWORD.
# PROD_BASE_URL=https://<prod-cloud-run-url>
# Repo root holding e2e/specs + playwright.config.ts. Defaults to four levels
# up from server/src/lib in the monorepo; set explicitly in the container.
# E2E_ROOT=/app
