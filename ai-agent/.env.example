# Gemini API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model name (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# PostgreSQL direct connection URL (Supabase Transaction Pooler or Session Pooler)
# Format: postgresql://[user]:[password]@[host]:[port]/[dbname]
# Use port 5432 for direct connection, 6543 for pooler
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Port — Cloud Run injects $PORT automatically; override locally if needed
PORT=8080

# ── Mapper Agent — Neo4j Aura (Governance knowledge graph) ───────────────
# Get these from console.neo4j.io for your Aura instance.
NEO4J_URI=neo4j+s://[INSTANCE-ID].databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
