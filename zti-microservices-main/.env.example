# Supabase — used ONLY for Google Auth (sign-in/sign-out/session)
# The anon key is safe to expose; it can only be used for auth operations
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API URL (all data operations go here)
VITE_API_BASE_URL=http://localhost:3001
